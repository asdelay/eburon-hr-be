generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model UserRole {
  id       Int    @id @default(autoincrement())
  userRole String @unique

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       Int     @id @default(autoincrement())
  fullName String
  email    String  @unique
  phone    String? @unique
  role     String

  //experience is measured in months
  experience Int? @default(0)

  userRole     UserRole      @relation(fields: [userRoleId], references: [id])
  userRoleId   Int
  interview    Interview?
  magicLinks   MagicLink[]
  hashedTokens HashedToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HashedToken {
  id        Int      @id @default(autoincrement())
  hash      String
  isValid   Boolean  @default(true)
  expiresAt DateTime

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  createdAt DateTime @default(now())
}

model MagicLink {
  id        Int      @id @default(autoincrement())
  body      String   @unique
  expiresAt DateTime
  isValid   Boolean  @default(true)

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interview {
  id         Int    @id @default(autoincrement())
  confidence Float
  label      String
  questions  Json
  answers    Json

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
